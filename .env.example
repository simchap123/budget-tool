# =============================================================================
# Budget Tool Environment Variables
# =============================================================================
# Copy to .env.local (development) or .env (production)
# NEVER commit actual values to git

# =============================================================================
# Frontend Configuration
# =============================================================================
# API endpoint for frontend
VITE_API_URL=http://localhost:8090
VITE_APP_NAME=Budget Tool

# =============================================================================
# Backend - Anthropic (Claude AI)
# =============================================================================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-v0-...

# =============================================================================
# Backend - Plaid (Banking Integration)
# =============================================================================
# Get from: https://dashboard.plaid.com/
PLAID_CLIENT_ID=client_id_...
PLAID_SECRET=secret_...
PLAID_ENV=sandbox  # sandbox, development, or production

# =============================================================================
# Backend - PocketBase
# =============================================================================
# Change these for production!
PB_ADMIN_EMAIL=admin@budgettool.local
PB_ADMIN_PASSWORD=changeme123

# =============================================================================
# Application Settings
# =============================================================================
NODE_ENV=development  # development or production
AI_MODEL=claude-3-5-sonnet-20241022
AI_CONFIDENCE_THRESHOLD=0.7

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_PLAID=true
ENABLE_UPLOADS=true
ENABLE_AI=true
